# Copy to apps/server/.env and set real values before running the API.

# --- Server ---
PORT=3000
DATABASE_URL=postgres://user:password@localhost:5432/scavenger

# Long random secret for signing team JWTs (e.g. openssl rand -hex 32)
TEAM_JWT_SECRET=jesuslovesmethisiknow

# Used as header X-Admin-Key for /api/admin/* routes
ADMIN_API_KEY=jesuslovesmethisiknow

# --- AWS S3 (server uses default credential chain if keys omitted: env, profile, instance/task role) ---
AWS_REGION=us-east-2
S3_BUCKET=scavenger-hunt-media
# Optional explicit keys for local dev:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# IAM (least privilege): attach a policy to the role/user used by the server with:
# - s3:PutObject, s3:AbortMultipartUpload, s3:ListMultipartUploadParts on arn:aws:s3:::YOUR_BUCKET/*
# - s3:CreateMultipartUpload, s3:CompleteMultipartUpload on arn:aws:s3:::YOUR_BUCKET/*
# Block public access on the bucket; use SSE-S3 or SSE-KMS as required by org policy.

# --- Mobile (optional; defaults to Metro host :3000 or localhost) ---
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
