{
  "expo": {
    "name": "Scavenger Hunt",
    "slug": "scavenger-hunt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "scavenger-hunt",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "bundleIdentifier": "com.christopherweinhardt.scavengerhunt",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Capture photos and videos for scavenger hunt tasks.",
        "NSMicrophoneUsageDescription": "Record audio with hunt videos.",
        "NSPhotoLibraryUsageDescription": "Save and upload hunt media from your library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "package": "com.christopherweinhardt.scavengerhunt",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to use the camera for hunt tasks.",
          "microphonePermission": "Allow $(PRODUCT_NAME) to record audio for hunt videos.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to photos for hunt uploads.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to use the camera for hunt tasks."
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-video",
      "expo-image",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3e84a6aa-3659-42f8-8646-58832a446ad9"
      }
    }
  }
}
